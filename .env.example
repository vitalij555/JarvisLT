# Copy to .env and fill in your values
OPENAI_API_KEY=sk-...
HA_TOKEN=your-long-lived-home-assistant-token

# Optional: GitHub MCP server token
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Serper.dev — Google search results (2500 free searches/month)
# Get key: https://serper.dev → Sign up → Dashboard → API Key
SERPER_API_KEY=

# Google Places API — find restaurants, shops, POIs nearby
# Enable in Cloud Console: Library → "Places API" → Enable
# Then: Credentials → Create Credentials → API key
GOOGLE_PLACES_API_KEY=

# Optional: Google credentials for Gmail/Calendar MCP
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...

# Neo4j graph memory (default: jarvispass — change to match docker-compose.yml)
NEO4J_PASSWORD=jarvispass
