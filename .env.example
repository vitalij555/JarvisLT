# Copy this file to .env and fill in your values.
# On Windows the installer (install.ps1) creates .env automatically.

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Neo4j graph memory (must match docker-compose.yml NEO4J_AUTH) ─────────────
NEO4J_PASSWORD=jarvispass

# ── Optional: Google web search (2500 free searches/month) ───────────────────
# Get key: https://serper.dev → Sign up → Dashboard → API Key
SERPER_API_KEY=

# ── Optional: Google Places API (restaurants, shops, POIs) ───────────────────
# Enable in Cloud Console: Library → "Places API" → Enable
# Then: Credentials → Create Credentials → API key
GOOGLE_PLACES_API_KEY=

# ── Optional: Home Assistant ─────────────────────────────────────────────────
HA_TOKEN=

# ── Optional: Google account for Gmail/Calendar MCP ──────────────────────────
# Set this if your Google account email differs from the default in main.py
GOOGLE_ACCOUNT_EMAIL=

# ── Optional: GitHub MCP server ──────────────────────────────────────────────
GITHUB_PERSONAL_ACCESS_TOKEN=
